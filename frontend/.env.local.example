# --- local dev (F0-F3: anvil + local backend) ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
# addresses from contracts/README.md (deterministic on fresh anvil);
# from M3 the source of truth is deployments.md
NEXT_PUBLIC_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
NEXT_PUBLIC_VAULT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
NEXT_PUBLIC_USDC_ADDRESS=0x0165878A594ca255338adfa4d48449f69242Eb8F
# optional -- only lib/receipts.ts's PaymentExecuted scan needs these; every
# other read/write works without them. Deploy block keeps the scan from
# walking pre-deploy history.
NEXT_PUBLIC_EXECUTOR_ADDRESS=
NEXT_PUBLIC_EXECUTOR_DEPLOY_BLOCK=
# dev wallet: 1 = sign with a local anvil key instead of Magic (offline dev)
NEXT_PUBLIC_DEV_WALLET=1
# anvil account #2 (the "subscriber" role in contracts/README.md's seed
# script -- matches ALICE, so the dev login lines up with seeded data).
# This is Foundry's public, well-known test-mnemonic key ("test test ...
# junk", index 2) -- not a secret, every default anvil instance has it.
NEXT_PUBLIC_DEV_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# --- F1+: Magic ---
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_...

# --- F4: ZeroDev (Kernel + session keys + paymaster) ---
# The bundler/paymaster RPC -- host is rpc.zerodev.app, NOT passkeys.zerodev.app
# (that's ZeroDev's separate WebAuthn/passkey service, unrelated to
# UserOperations). Pattern verified live 2026-07-14: rpc.zerodev.app/api/v3/
# {projectId}/chain/{chainId} returns an allowlist response (endpoint is
# real) vs. a plain 404 for the passkey host. Confirm against your ZeroDev
# dashboard's project page if this ever needs re-deriving. Only reachable on
# a real chain (NEXT_PUBLIC_CHAIN_ID must be 421614) -- doesn't know anvil.
NEXT_PUBLIC_ZERODEV_RPC=https://rpc.zerodev.app/api/v3/12a695bf-0af1-4d36-b1d4-19a968b503fa/chain/421614

# --- F6: Particle UA (flag-gated; mainnet-only) ---
NEXT_PUBLIC_PARTICLE_ENABLED=0
NEXT_PUBLIC_PARTICLE_PROJECT_ID=...
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=...
NEXT_PUBLIC_PARTICLE_APP_ID=...

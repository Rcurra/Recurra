PORT=3001
OPENFORT_SECRET_KEY=sk_...
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
SUBSCRIPTION_REGISTRY_ADDRESS=0x...
SUBSCRIPTION_VAULT_ADDRESS=0x...
# PaymentExecutor address — optional (scheduler is log-only without it), required to fire.
EXECUTOR_ADDRESS=0x...
# First block to scan for PaymentExecuted logs (GET /api/payments) — the
# executor's deploy block, from ../deployments.md. Defaults to 0 (fine on
# anvil) but should always be set on a public network or history scans crawl
# from genesis.
EXECUTOR_DEPLOY_BLOCK=0
# Local signing path for the scheduler: set to fire executePayment in-process
# against ARBITRUM_RPC (anvil / M2 e2e — must be the key set as authorizedExecutor
# in Deploy.s.sol). Leave UNSET in staging/prod, where Openfort (M3) signs instead.
# LOCAL_SIGNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# The Openfort TEE wallet's own address (from the Openfort dashboard) — only
# needed on the Openfort path (LOCAL_SIGNER_PRIVATE_KEY unset). Used solely to
# verify it matches on-chain authorizedExecutor at boot; unset means the
# scheduler stays disabled until it's provided (see AppState::new's signer check).
# OPENFORT_WALLET_ADDRESS=0x...
# The same wallet's Openfort account ID (acc_..., from `openfort accounts evm
# create`) — required to actually submit a transaction intent through it.
# OPENFORT_ACCOUNT_ID=acc_...
# EC P-256 wallet-auth secret (Openfort dashboard -> Backend wallet keys ->
# Wallet secret) — required by the vendored openfort-cli (see openfort-cli/)
# to actually sign/send through a backend wallet.
# OPENFORT_WALLET_SECRET=...
# Publishable key — the CLI's account-creation commands require it.
# OPENFORT_PUBLISHABLE_KEY=pk_...
SCHEDULER_INTERVAL_SECS=60
